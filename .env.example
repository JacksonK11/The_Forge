# ═══════════════════════════════════════════════════════════════════════
# THE FORGE — Environment Variables Template
# .env.example
#
# Copy this file to .env and fill in all values before running.
# Never commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════

# ── Application ─────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000

# ── Security ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
API_SECRET_KEY=your_secret_key_here

# ── Database ────────────────────────────────────────────────────────────
# Local dev: postgresql+asyncpg://forge:forge_dev_password@localhost:5432/the_forge
# Fly.io: automatically injected as DATABASE_URL when postgres is attached
DATABASE_URL=postgresql+asyncpg://forge:forge_dev_password@localhost:5432/the_forge

# ── Redis ───────────────────────────────────────────────────────────────
# Local dev: redis://localhost:6379
# Fly.io: copy from `flyctl redis create` output
REDIS_URL=redis://localhost:6379

# ── Claude AI ───────────────────────────────────────────────────────────
# Get from: console.anthropic.com → API Keys → Create Key (name: the-forge)
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Primary model: reasoning, code generation, synthesis
CLAUDE_MODEL=claude-sonnet-4-6

# Fast model: classification, validation, quick checks
CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001

# ── OpenAI ──────────────────────────────────────────────────────────────
# Get from: platform.openai.com → API Keys
# Used only for text-embedding-3-small (knowledge engine embeddings)
OPENAI_API_KEY=sk-YOUR_KEY_HERE

# ── Tavily ──────────────────────────────────────────────────────────────
# Get from: tavily.com → Dashboard → API Keys
# Free tier: 1,000 searches/month — covers all knowledge engine domains
TAVILY_API_KEY=tvly-YOUR_KEY_HERE

# ── Telegram ────────────────────────────────────────────────────────────
# Bot token: BotFather → /newbot → copy token
# Chat ID: send message to bot, then GET https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# ── Sentry (optional) ───────────────────────────────────────────────────
# Get from: sentry.io → Create Project → Python/FastAPI
# Leave empty to disable error tracking
SENTRY_DSN=

# ── GitHub (github.com → Settings → Developer settings → Personal access tokens)
# Required for: auto-push of generated codebases, update mode (clone/commit/push)
# Scopes needed: repo (full control of private repositories)
GITHUB_TOKEN=your_github_personal_access_token_with_repo_scope

# ── The Office (set when Agent 5 is deployed)
# Used to notify The Office of agent registrations and receive build requests
# Leave empty until Agent 5 is running
OFFICE_WEBHOOK_URL=

# ── Dashboard ───────────────────────────────────────────────────────────
# URL of the API server (used by React frontend)
VITE_API_BASE_URL=http://localhost:8000
VITE_API_SECRET_KEY=your_secret_key_here
